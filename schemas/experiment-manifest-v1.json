{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.bonsai.dev/experiment-manifest/v1",
  "title": "BONSAI experiment manifest v1",
  "description": "Immutable, fully resolved declaration of one governed BONSAI run. Eligibility is not publication authorization.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "run_id",
    "source",
    "adapter",
    "environment",
    "seeds",
    "track",
    "resource_profile",
    "metrics",
    "scenario",
    "expected_counters",
    "publication_eligibility"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "manifest_id": {"$ref": "#/$defs/uuid"},
    "run_id": {"$ref": "#/$defs/uuid"},
    "source": {"$ref": "#/$defs/source"},
    "adapter": {"$ref": "#/$defs/configured_component"},
    "environment": {"$ref": "#/$defs/configured_component"},
    "seeds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/seed"}
    },
    "track": {"$ref": "#/$defs/track_declaration"},
    "resource_profile": {"$ref": "#/$defs/resource_profile"},
    "metrics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/metric"}
    },
    "scenario": {"$ref": "#/$defs/scenario"},
    "expected_counters": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/expected_counter"}
    },
    "publication_eligibility": {"$ref": "#/$defs/publication_eligibility"}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source": {
            "properties": {"dirty": {"const": true}},
            "required": ["dirty"]
          }
        },
        "required": ["source"]
      },
      "then": {
        "properties": {
          "source": {"required": ["dirty_patch_sha256"]},
          "publication_eligibility": {
            "properties": {"status": {"const": "ineligible"}},
            "required": ["status"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "publication_eligibility": {
            "properties": {"status": {"const": "eligible"}},
            "required": ["status"]
          }
        },
        "required": ["publication_eligibility"]
      },
      "then": {
        "properties": {
          "source": {
            "properties": {"dirty": {"const": false}},
            "required": ["dirty"]
          }
        }
      }
    }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "config": {
      "type": "object",
      "description": "Fully resolved immutable configuration; producers may use an empty object but may not apply omitted runtime defaults."
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision", "dirty"],
      "properties": {
        "repository": {"type": "string", "format": "uri", "minLength": 1},
        "revision": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "dirty": {"type": "boolean"},
        "dirty_patch_sha256": {"$ref": "#/$defs/sha256"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"dirty": {"const": false}},
            "required": ["dirty"]
          },
          "then": {"not": {"required": ["dirty_patch_sha256"]}}
        }
      ]
    },
    "configured_component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "version", "entrypoint", "config"],
      "properties": {
        "component_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
        "version": {"$ref": "#/$defs/version"},
        "entrypoint": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "config": {"$ref": "#/$defs/config"}
      }
    },
    "seed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seed_id", "value"],
      "properties": {
        "seed_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "value": {"type": "string", "pattern": "^(0|[1-9][0-9]{0,19})$"}
      }
    },
    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "source", "capacity_transitions"],
      "properties": {
        "enabled": {"type": "boolean"},
        "source": {"enum": ["none", "agent_local", "offline_dataset", "observer"]},
        "capacity_transitions": {"type": "integer", "minimum": 0}
      },
      "allOf": [
        {
          "if": {
            "properties": {"enabled": {"const": false}},
            "required": ["enabled"]
          },
          "then": {
            "properties": {
              "source": {"const": "none"},
              "capacity_transitions": {"const": 0}
            }
          },
          "else": {
            "properties": {
              "source": {"enum": ["agent_local", "offline_dataset", "observer"]},
              "capacity_transitions": {"type": "integer", "minimum": 1}
            }
          }
        }
      ]
    },
    "track_declaration": {
      "type": "object",
      "description": "Declared intent only; BC-05 derives actual track eligibility from runtime facts.",
      "additionalProperties": false,
      "required": [
        "declared_track",
        "batch_size",
        "replay",
        "offline_updates",
        "observer_data_access",
        "privileged_inputs",
        "human_labels"
      ],
      "properties": {
        "declared_track": {"enum": ["A", "B", "C", "D"]},
        "batch_size": {"type": "integer", "minimum": 1},
        "replay": {"$ref": "#/$defs/replay"},
        "offline_updates": {"type": "boolean"},
        "observer_data_access": {"type": "boolean"},
        "privileged_inputs": {"type": "boolean"},
        "human_labels": {"type": "boolean"}
      }
    },
    "resource_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "step_limit",
        "wall_time_limit_ns",
        "agent_rss_limit_bytes",
        "agent_storage_limit_bytes",
        "observer_output_limit_bytes",
        "per_step_cpu_time_limit_ns",
        "action_deadline_ns",
        "energy_tier",
        "energy_budget_uj"
      ],
      "properties": {
        "profile_id": {"enum": ["S", "C", "A", "L", "custom"]},
        "step_limit": {"type": "integer", "minimum": 1},
        "wall_time_limit_ns": {"type": "integer", "minimum": 1},
        "agent_rss_limit_bytes": {"type": "integer", "minimum": 1},
        "agent_storage_limit_bytes": {"type": "integer", "minimum": 1},
        "observer_output_limit_bytes": {"type": "integer", "minimum": 1},
        "per_step_cpu_time_limit_ns": {"type": "integer", "minimum": 1},
        "action_deadline_ns": {"type": "integer", "minimum": 1},
        "energy_tier": {"enum": ["E0", "E1", "E2", "E3"]},
        "energy_budget_uj": {
          "oneOf": [
            {"type": "integer", "minimum": 1},
            {"type": "null"}
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"energy_tier": {"const": "E0"}},
            "required": ["energy_tier"]
          },
          "then": {"properties": {"energy_budget_uj": {"type": "null"}}},
          "else": {"properties": {"energy_budget_uj": {"type": "integer", "minimum": 1}}}
        }
      ]
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "version", "required", "parameters"],
      "properties": {
        "metric_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
        "version": {"$ref": "#/$defs/version"},
        "required": {"type": "boolean"},
        "parameters": {"$ref": "#/$defs/config"}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "version", "family", "variant", "reward_unit_id", "config"],
      "properties": {
        "scenario_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
        "version": {"$ref": "#/$defs/version"},
        "family": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
        "variant": {"type": "string", "minLength": 1},
        "reward_unit_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
        "config": {"$ref": "#/$defs/config"}
      }
    },
    "expected_counter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["counter_id", "unit", "acceptable_basis", "required_for_run"],
      "properties": {
        "counter_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
        "unit": {"enum": ["ns", "B", "1", "uJ", "uW"]},
        "acceptable_basis": {"enum": ["measured", "estimated", "measured_or_estimated"]},
        "required_for_run": {"type": "boolean"}
      }
    },
    "publication_eligibility": {
      "type": "object",
      "description": "Pre-run eligibility declaration only; it never authorizes external publication.",
      "additionalProperties": false,
      "required": ["status", "reason_codes"],
      "properties": {
        "status": {"enum": ["eligible", "ineligible"]},
        "reason_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"status": {"const": "eligible"}},
            "required": ["status"]
          },
          "then": {"properties": {"reason_codes": {"maxItems": 0}}},
          "else": {"properties": {"reason_codes": {"minItems": 1}}}
        }
      ]
    }
  }
}
